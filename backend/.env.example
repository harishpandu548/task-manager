PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskflow?schema=public

JWT_ACCESS_SECRET=replace_with_at_least_32_characters_secret
JWT_REFRESH_SECRET=replace_with_at_least_32_characters_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
